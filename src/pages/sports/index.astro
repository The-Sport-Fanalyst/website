---
export const prerender = true;
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import HeadConfetti from '../../components/HeadConfetti.astro';

const sports = (await getCollection('sports')).sort((a, b) => a.data.order - b.data.order);
const projects = await getCollection('projects');
const countFor = (name: string) =>
  projects.filter((p) => p.data.sport.toLowerCase() === name.toLowerCase()).length;

// Split: sports that already have projects vs. sports still open ("be the first").
const withProjects = sports.filter((s) => countFor(s.data.name) > 0);
const empty = sports.filter((s) => countFor(s.data.name) === 0);

const olympicCount = sports.filter((s) => s.data.olympic).length;
const paralympicCount = sports.filter((s) => s.data.paralympic).length;
---
<Base title="Sports — The Sport Fanalyst">
  <section class="head">
    
    <HeadConfetti />
<div class="wrap">
      <p class="eyebrow">Directory</p>
      <h1>Sports</h1>
      <p class="lead">
        <b>Every sport deserves a place here.</b><br />
        Whether it's non-disabled, Para, or an emerging sport, The Sport Fanalyst is a home for
        the data, research, models, and tools that help us understand the game.
      </p>
      <p class="lead">
        Some sports already have projects. Others are waiting for their first contribution.
        Whether you share a full dashboard, a dataset, a research project, or a small piece of
        knowledge—every contribution helps build the bigger picture.
      </p>
      <div class="stats">
        <span><b>{sports.length}</b> sports</span>
        <span><b>{olympicCount}</b> Olympic</span>
        <span><b>{paralympicCount}</b> Paralympic</span>
        <span><b>{withProjects.length}</b> with projects</span>
      </div>
    </div>
  </section>

  {withProjects.length > 0 && (
    <section class="wrap section">
      <header class="band"><h2>Active sports</h2></header>
      <div class="dir">
        {withProjects.map((s, i) => (
          <a href={`/sports/${s.data.slug}`} class="row">
            <span class="row__body">
              <span class="row__name">{s.data.name}</span>
            </span>
            <span class="row__side">
              <span class="row__games">
                {s.data.olympic && <i class="chip chip--olympic">Olympic</i>}
                {s.data.paralympic && <i class="chip chip--paralympic">Paralympic</i>}
              </span>
              <span class="row__count">{countFor(s.data.name)} {countFor(s.data.name) === 1 ? 'project' : 'projects'}</span>
            </span>
            <span class="row__arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </section>
  )}

  {empty.length > 0 && (
    <section class="wrap section">
      <header class="band band--open">
        <h2>Be the first</h2>
        <a href="/submit" class="band__link">Start a project →</a>
      </header>
      <p class="band__lead">
        These sports is waiting for its first contribution — a dataset, a question, a model, or an app.
      </p>
      <div class="grid">
        {empty.map((s) => (
          <a href={`/sports/${s.data.slug}`} class="tile">
            <span class="tile__name">{s.data.name}</span>
            <span class="tile__games">
              {s.data.olympic && <i class="chip chip--olympic">Olympic</i>}
              {s.data.paralympic && <i class="chip chip--paralympic">Paralympic</i>}
            </span>
            <span class="tile__cta">Be the first →</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="wrap section--tight">
    <p class="note">
      Don't see your sport? Propose it on the
      <a href="/community">community board</a> — new hubs start as a single dataset or question.
    </p>
  </section>
</Base>

<style>
  .head { border-bottom: 1px solid var(--line); padding-block: clamp(2.4rem, 5vw, 4rem) 2.4rem; }
  .head h1 { font-size: clamp(2.2rem, 5vw, 3.4rem); letter-spacing: -.03em; margin: 1rem 0 .8rem; }
  .lead { max-width: 62ch; color: var(--ink-soft); margin: 0 0 1.4rem; }
  .stats { display: flex; gap: 1.8rem; flex-wrap: wrap; font-family: var(--mono); font-size: .76rem; text-transform: uppercase; letter-spacing: .04em; color: var(--gray); }
  .stats b { font-family: var(--display); font-size: 1.1rem; color: var(--ink); }

  .band { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; border-bottom: 2px solid var(--ink); padding-bottom: .7rem; margin-bottom: 1.4rem; }
  .band h2 { margin: 0; font-size: clamp(1.4rem, 3vw, 2rem); letter-spacing: -.02em; }
  .band--open { border-color: var(--lane); }
  .band__link { font-family: var(--mono); font-size: .78rem; text-transform: uppercase; text-decoration: none; color: var(--brick); white-space: nowrap; }
  .band__link:hover { text-decoration: underline; }
  .band__lead { color: var(--gray); margin: -.6rem 0 1.6rem; max-width: 62ch; }

  .dir { border-top: 0; }
  .row {
    display: grid; grid-template-columns: 1fr auto auto; align-items: center; gap: 1.2rem;
    padding: 1.5rem 0; border-bottom: 1px solid var(--line); text-decoration: none; color: var(--ink);
    transition: padding-left .15s ease;
  }
  .row:hover { padding-left: .8rem; background: linear-gradient(90deg, var(--paper-dim), transparent 40%); }
  .row__num { font-family: var(--mono); font-size: .8rem; color: var(--gray-soft); }
  .row__icon { font-size: 1.6rem; color: var(--brick); width: 1.6rem; }
  .row__name { font-family: var(--display); font-weight: 600; font-size: 1.4rem; display: block; letter-spacing: -.01em; }
  .row__desc { color: var(--gray); font-size: .92rem; display: block; margin-top: .25rem; max-width: 60ch; }
  .row__side { display: flex; flex-direction: column; align-items: flex-end; gap: .5rem; }
  .row__games { display: flex; gap: .35rem; }
  .row__count { font-family: var(--mono); font-size: .72rem; text-transform: uppercase; color: var(--gray); }
  .row__arrow { font-size: 1.3rem; color: var(--gray-soft); }
  .row:hover .row__arrow { color: var(--brick); }

  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: 1px; background: var(--line); border: 1px solid var(--line); }
  .tile {
    background: var(--paper); padding: 1.2rem 1.3rem; text-decoration: none; color: var(--ink);
    display: flex; flex-direction: column; gap: .5rem; position: relative; transition: background .15s;
    border-top: var(--rail) solid transparent;
  }
  .tile:hover { background: var(--paper-dim); border-top-color: var(--lane); }
  .tile__icon { font-size: 1.5rem; color: var(--brick); }
  .tile__name { font-family: var(--display); font-weight: 600; font-size: 1.15rem; letter-spacing: -.01em; }
  .tile__games { display: flex; gap: .35rem; flex-wrap: wrap; }
  .tile__cta { font-family: var(--mono); font-size: .68rem; text-transform: uppercase; letter-spacing: .04em; color: var(--gray-soft); margin-top: .3rem; }
  .tile:hover .tile__cta { color: var(--brick); }

  .note { color: var(--gray); font-size: .95rem; }
  .note a { color: var(--brick); }

  @media (max-width: 720px) {
    .row { grid-template-columns: 1fr; gap: .8rem 1rem; }
    .row__side { flex-direction: row; align-items: center; justify-content: space-between; }
    .row__arrow { display: none; }
  }
</style>
