---
export const prerender = true;
import Base from '../layouts/Base.astro';

const steps = [
  { n: 'Create an account', t: 'Sign in with GitHub. You start as a Member — you can comment, join projects, and post to the community board right away.' },
  { n: 'Submit your first contribution', t: 'Open a pull request using one of the templates below, or post an idea to the board. It can be data, research, a model, an app, or a fix.' },
  { n: 'Review', t: 'A maintainer or admin reviews your submission for sources, methodology, and clear authorship — the three things every analysis here must show.' },
  { n: 'Approved → Contributor', t: 'Once merged, you become a Contributor. From then on, normal edits flow without gatekeeping.' },
];

const roles = [
  { role: 'Visitor', can: ['Browse sports', 'View projects', 'Read stories'], accent: 'gray' },
  { role: 'Member', can: ['Create a profile', 'Comment', 'Join projects', 'Submit ideas'], accent: 'slate' },
  { role: 'Contributor', can: ['Submit projects', 'Create content', 'Update pages'], accent: 'lane' },
  { role: 'Maintainer', can: ['Review submissions', 'Manage sport sections'], accent: 'brick' },
  { role: 'Admin', can: ['Full control', 'Founder'], accent: 'ink' },
];

const reviewRequired = ['Deleting projects', 'Major changes', 'Removing data', 'Ownership changes'];
const autoOk = ['Typo fixes', 'Formatting', 'Metadata updates'];

const templates = [
  { id: 'project', name: 'Project submission', fields: ['title', 'creator', 'sport', 'category', 'description', 'github_url', 'data_sources', 'status'], for: 'Any project: Data, Research, Models, or Apps.' },
  { id: 'data', name: 'Data submission', fields: ['dataset name', 'sport', 'source(s)', 'license', 'format', 'data dictionary', 'update cadence'], for: 'Datasets, APIs, and athlete databases.' },
  { id: 'research', name: 'Research submission', fields: ['question', 'sport', 'methodology', 'data sources', 'findings', 'reproducible notebook'], for: 'Articles, studies, and visual storytelling.' },
  { id: 'app', name: 'App submission', fields: ['app name', 'sport', 'what it does', 'github_url', 'demo_url', 'data sources', 'tech stack'], for: 'Dashboards, calculators, and interactive tools.' },
];
---
<Base title="Contribute — The Sport Fanalyst">
  <section class="head">
    <div class="wrap">
      <p class="eyebrow">How it works</p>
      <h1>Contribute to the open record.</h1>
      <p class="lead">
        The Sport Fanalyst runs on an open-source workflow. GitHub is the source of truth; this
        site is the place to discover and collaborate. Here's how to join in — whether or not
        you write code.
      </p>
    </div>
  </section>

  <!-- WORKFLOW -->
  <section class="wrap section">
    <header class="band"><h2>The contribution workflow</h2></header>
    <ol class="steps">
      {steps.map((s, i) => (
        <li class="step">
          <span class="step__n">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <h3>{s.n}</h3>
            <p>{s.t}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <!-- ROLES -->
  <section class="roles-wrap">
    <div class="wrap section">
      <header class="band band--invert"><h2>Roles &amp; permissions</h2></header>
      <p class="band__lead">Permissions grow with trust. Everyone is welcome at the door.</p>
      <div class="roles">
        {roles.map((r) => (
          <div class={`role role--${r.accent}`}>
            <h3>{r.role}</h3>
            <ul>{r.can.map((c) => <li>{c}</li>)}</ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- REVIEW RULES -->
  <section class="wrap section">
    <div class="rules">
      <div class="rule rule--review">
        <h3><span class="dot"></span>Requires review</h3>
        <p>High-impact changes get a second pair of eyes before they land.</p>
        <ul>{reviewRequired.map((x) => <li>{x}</li>)}</ul>
      </div>
      <div class="rule rule--auto">
        <h3><span class="dot"></span>Lands automatically</h3>
        <p>Low-risk edits don't need gatekeeping — keep the friction where it matters.</p>
        <ul>{autoOk.map((x) => <li>{x}</li>)}</ul>
      </div>
    </div>
  </section>

  <!-- TEMPLATES -->
  <section id="templates" class="wrap section">
    <header class="band"><h2>Submit a contribution</h2></header>
    <p class="band__lead">The guided form fills in the right fields and opens a pull request for you — no Markdown by hand.</p>
    <a href="/submit" class="btn submit-cta">Start a guided submission →</a>
    <p class="tpls-intro">Prefer to write the file yourself? These are the fields each type needs.</p>
    <div class="tpls">
      {templates.map((t) => (
        <article class="tpl" id={t.id}>
          <h3>{t.name}</h3>
          <p class="tpl__for">{t.for}</p>
          <ul class="tpl__fields">
            {t.fields.map((f) => <li><code>{f}</code></li>)}
          </ul>
          <a href="/submit" class="tpl__link">Use the guided form →</a>
        </article>
      ))}
    </div>
  </section>

  <!-- TRUST -->
  <section class="trust-cta">
    <div class="wrap trust-cta__inner">
      <p class="eyebrow">The standard</p>
      <h2>Every analysis shows three things.</h2>
      <div class="trust-cta__grid">
        <div><b>Sources</b><span>Where the data came from, cited so anyone can check.</span></div>
        <div><b>Methodology</b><span>How the result was produced, in enough detail to reproduce.</span></div>
        <div><b>Creator</b><span>Who made it, credited by name and handle.</span></div>
      </div>
      <a href="/community" class="btn">Start on the community board →</a>
    </div>
  </section>
</Base>

<style>
  .head { border-bottom: 1px solid var(--line); padding-block: clamp(2.4rem, 5vw, 4rem) 2.4rem; }
  .head h1 { font-size: clamp(2.2rem, 5vw, 3.4rem); letter-spacing: -.03em; margin: 1rem 0 .8rem; max-width: 18ch; }
  .lead { max-width: 62ch; color: var(--ink-soft); margin: 0; }

  .band { display: flex; align-items: baseline; justify-content: space-between; border-bottom: 2px solid var(--ink); padding-bottom: .7rem; }
  .band h2 { margin: 0; font-size: clamp(1.4rem, 3vw, 2rem); letter-spacing: -.02em; }
  .band__lead { color: var(--gray); margin: .9rem 0 1.6rem; }

  .steps { list-style: none; padding: 0; margin: 1.6rem 0 0; counter-reset: none; }
  .step { display: grid; grid-template-columns: auto 1fr; gap: 1.5rem; padding: 1.4rem 0; border-bottom: 1px solid var(--line); align-items: start; }
  .step__n { font-family: var(--mono); font-size: 1.1rem; color: var(--brick); padding-top: .2rem; }
  .step h3 { font-size: 1.2rem; margin: 0 0 .3rem; }
  .step p { margin: 0; color: var(--ink-soft); max-width: 70ch; }

  .roles-wrap { background: var(--ink); color: var(--paper); }
  .band--invert { border-color: var(--lane); }
  .band--invert h2 { color: var(--paper); }
  .roles-wrap .band__lead { color: var(--gray-soft); }
  .roles { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1px; background: #2A2A26; border: 1px solid #2A2A26; }
  .role { background: var(--ink); padding: 1.3rem 1.1rem; border-top: var(--rail) solid var(--gray); }
  .role--gray { border-top-color: var(--gray); }
  .role--slate { border-top-color: var(--slate); }
  .role--lane { border-top-color: var(--lane); }
  .role--brick { border-top-color: var(--brick); }
  .role--ink { border-top-color: var(--paper); }
  .role h3 { font-size: 1.1rem; margin: 0 0 .8rem; }
  .role ul { list-style: none; padding: 0; margin: 0; }
  .role li { font-size: .85rem; color: var(--gray-soft); padding: .3rem 0; border-bottom: 1px dashed #2A2A26; }
  @media (max-width: 820px) { .roles { grid-template-columns: repeat(2, 1fr); } }

  .rules { display: grid; grid-template-columns: 1fr 1fr; gap: 1.1rem; }
  .rule { border: 1px solid var(--line); padding: 1.4rem; border-top: var(--rail) solid var(--ink); }
  .rule--review { border-top-color: var(--brick); }
  .rule--auto { border-top-color: var(--lane); }
  .rule h3 { display: flex; align-items: center; gap: .6rem; margin: 0 0 .5rem; font-size: 1.15rem; }
  .rule .dot { width: 10px; height: 10px; }
  .rule--review .dot { background: var(--brick); }
  .rule--auto .dot { background: var(--lane); }
  .rule p { color: var(--gray); font-size: .9rem; margin: 0 0 1rem; }
  .rule ul { list-style: none; padding: 0; margin: 0; }
  .rule li { font-family: var(--mono); font-size: .82rem; padding: .4rem 0; border-bottom: 1px solid var(--line); }
  @media (max-width: 640px) { .rules { grid-template-columns: 1fr; } }

  .tpls { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.1rem; margin-top: 1.6rem; }
  .submit-cta { margin-bottom: 1.4rem; }
  .tpls-intro { color: var(--gray); font-size: .92rem; margin: 0; border-top: 1px solid var(--line); padding-top: 1.4rem; }
  .tpl { border: 1px solid var(--line); border-left: var(--rail) solid var(--slate); padding: 1.4rem; scroll-margin-top: 90px; }
  .tpl h3 { margin: 0 0 .3rem; font-size: 1.15rem; }
  .tpl__for { color: var(--gray); font-size: .88rem; margin: 0 0 1rem; }
  .tpl__fields { list-style: none; padding: 0; margin: 0 0 1.2rem; display: flex; flex-wrap: wrap; gap: .4rem; }
  .tpl__fields code { font-family: var(--mono); font-size: .74rem; background: var(--paper-dim); padding: .2rem .5rem; color: var(--ink-soft); }
  .tpl__link { font-family: var(--mono); font-size: .78rem; text-transform: uppercase; color: var(--brick); text-decoration: none; }
  .tpl__link:hover { text-decoration: underline; }

  .trust-cta { background: var(--lane); margin-top: 2rem; }
  .trust-cta__inner { padding-block: clamp(2.6rem, 5vw, 4rem); }
  .trust-cta .eyebrow::before { background: var(--ink); }
  .trust-cta h2 { font-size: clamp(1.6rem, 4vw, 2.6rem); letter-spacing: -.02em; margin: .8rem 0 1.6rem; }
  .trust-cta__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-bottom: 2rem; }
  .trust-cta__grid b { font-family: var(--display); font-size: 1.2rem; display: block; margin-bottom: .3rem; }
  .trust-cta__grid span { color: var(--ink-soft); font-size: .92rem; }
  .trust-cta .btn:hover { box-shadow: 4px 4px 0 var(--paper); }
  @media (max-width: 700px) { .trust-cta__grid { grid-template-columns: 1fr; gap: 1rem; } }
</style>
