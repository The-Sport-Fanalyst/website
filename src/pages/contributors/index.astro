---
export const prerender = true;
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import HeadConfetti from '../../components/HeadConfetti.astro';
import { roleForLogin, type Role } from '../../lib/roles';

const projects = await getCollection('projects');

// Derive contributors from project authorship: anyone who is the creator of, or
// a listed contributor on, at least one project. No separate profile files —
// contributing a project is what makes you a contributor. Remove your last
// project and you drop off this list automatically.
type Person = { name: string; projects: typeof projects; role: Role };
const byName = new Map<string, Person>();

for (const p of projects) {
  const names = [p.data.creator, ...p.data.contributors].filter(Boolean);
  for (const name of names) {
    if (!byName.has(name)) {
      // role looked up by treating the stored name as a GitHub login (creators
      // are saved as the login); falls back to Contributor since they've shipped.
      const looked = roleForLogin(name);
      const role: Role = looked === 'Member' ? 'Contributor' : looked;
      byName.set(name, { name, projects: [], role });
    }
    byName.get(name)!.projects.push(p);
  }
}

const roleOrder: Role[] = ['Admin', 'Maintainer', 'Contributor'];
const people = [...byName.values()].sort((a, b) => {
  const r = roleOrder.indexOf(a.role) - roleOrder.indexOf(b.role);
  return r !== 0 ? r : b.projects.length - a.projects.length;
});

const initials = (name: string) =>
  name.replace(/[^a-zA-Z0-9 ]/g, '').split(/\s+/).map((w) => w[0]).join('').slice(0, 2).toUpperCase() || name.slice(0, 2).toUpperCase();

const roleBlurb: Record<Role, string> = {
  Admin: 'Founder. Full control of the platform.',
  Maintainer: 'Trusted members who review submissions and steward sport sections.',
  Contributor: 'Members who have shipped at least one project.',
  Member: 'Joined the community.',
};
---
<Base title="Contributors — The Sport Fanalyst">
  <section class="head">
    
    <HeadConfetti />
<div class="wrap">
      <p class="eyebrow">People</p>
      <h1>Contributors</h1>
      <p class="lead">
        Every contributor has built something that adds to the collective knowledge of sport.
        Share a project, analysis, dataset, or tool—and your contribution becomes part of the
        open record.
      </p>
    </div>
  </section>

  <section class="wrap section">
    {people.length === 0 ? (
      <div class="empty">
        <p class="eyebrow">No contributors yet</p>
        <h2>This is where the community will be.</h2>
        <p>The moment someone's first project is merged, they show up here. Be the first.</p>
        <div class="empty__cta">
          <a href="/submit" class="btn">Submit a project →</a>
          <a href="/contribute" class="btn btn--ghost">How it works</a>
        </div>
      </div>
    ) : (
      roleOrder.map((role) => {
        const group = people.filter((c) => c.role === role);
        if (group.length === 0) return null;
        return (
          <section class="rsec">
            <header class="rhead">
              <h2>{role}<i>{group.length}</i></h2>
              <p>{roleBlurb[role]}</p>
            </header>
            <div class="cards">
              {group.map((c) => (
                <div class="pc">
                  <span class="pc__av">{initials(c.name)}</span>
                  <span class="pc__name">{c.name}</span>
                  <span class="pc__handle">@{c.name}</span>
                  <span class="pc__projects">
                    {c.projects.slice(0, 3).map((p) => (
                      <a href={`/projects/${p.id}`} class="pc__proj">{p.data.title}</a>
                    ))}
                  </span>
                  <span class="pc__foot">
                    <span class="pc__count">{c.projects.length} {c.projects.length === 1 ? 'project' : 'projects'}</span>
                  </span>
                </div>
              ))}
            </div>
          </section>
        );
      })
    )}
  </section>
</Base>

<style>
  .head { border-bottom: 1px solid var(--line); padding-block: clamp(2.4rem, 5vw, 4rem) 2.4rem; }
  .head h1 { font-size: clamp(2.2rem, 5vw, 3.4rem); letter-spacing: -.03em; margin: 1rem 0 .8rem; }
  .empty { border: 1px dashed var(--line); border-left: var(--rail) solid var(--lane); padding: 2rem; max-width: 60ch; }
  .empty h2 { font-size: 1.6rem; margin: .4rem 0 .6rem; letter-spacing: -.02em; }
  .empty p { color: var(--ink-soft); margin: 0 0 1rem; }
  .empty__cta { display: flex; gap: .7rem; flex-wrap: wrap; margin-top: 1.2rem; }
  .lead { max-width: 60ch; color: var(--ink-soft); margin: 0; }

  .rsec { margin-bottom: 3rem; }
  .rhead { border-bottom: 2px solid var(--ink); padding-bottom: .7rem; margin-bottom: 1.4rem; }
  .rhead h2 { font-size: 1.4rem; margin: 0; display: flex; align-items: center; gap: .6rem; letter-spacing: -.02em; }
  .rhead h2 i { font-style: normal; font-family: var(--mono); font-size: .8rem; color: var(--paper); background: var(--brick); padding: .1rem .5rem; }
  .rhead p { margin: .3rem 0 0; color: var(--gray); font-size: .92rem; }

  .cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.1rem; }
  .pc { border: 1px solid var(--line); border-top: var(--rail) solid var(--ink); padding: 1.3rem; display: flex; flex-direction: column; gap: .5rem; }
  .pc__av { width: 2.6rem; height: 2.6rem; display: flex; align-items: center; justify-content: center; background: var(--ink); color: var(--lane); font-family: var(--display); font-weight: 600; }
  .pc__name { font-family: var(--display); font-weight: 600; font-size: 1.15rem; }
  .pc__handle { font-family: var(--mono); font-size: .78rem; color: var(--gray); }
  .pc__projects { display: flex; flex-direction: column; gap: .25rem; margin: .4rem 0; }
  .pc__proj { font-size: .88rem; color: var(--brick); text-decoration: none; }
  .pc__proj:hover { text-decoration: underline; }
  .pc__foot { margin-top: auto; padding-top: .6rem; border-top: 1px dashed var(--line); }
  .pc__count { font-family: var(--mono); font-size: .72rem; text-transform: uppercase; letter-spacing: .04em; color: var(--gray); }
</style>
