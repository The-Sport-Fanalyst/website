---
import { fetchAnnouncements } from '../lib/discussions';

// Slim homepage strip showing the latest approved announcement, if any.
// Renders nothing when there are no announcements (so the homepage is unaffected
// until someone approved posts one).
const items = await fetchAnnouncements(1);
const a = items[0];
const fmt = (iso: string) =>
  new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
---
{a && (
  <a class="ann" href={a.url} target="_blank" rel="noopener">
    <span class="ann__tag">Announcement</span>
    <span class="ann__title">{a.title}</span>
    {a.excerpt && <span class="ann__excerpt">— {a.excerpt}{a.excerpt.length >= 140 ? '…' : ''}</span>}
    <span class="ann__meta">
      {a.author && <>by {a.author} · </>}{fmt(a.createdAt)} ↗
    </span>
  </a>
)}

<style>
  .ann {
    display: flex; align-items: center; gap: .8rem;
    background: var(--lane); color: var(--ink);
    text-decoration: none;
    padding: .65rem var(--gutter);
    border-bottom: 1px solid var(--ink);
    font-size: .9rem;
    flex-wrap: wrap;
  }
  .ann:hover { background: #b9e83f; }
  .ann__tag {
    font-family: var(--mono); font-size: .66rem; text-transform: uppercase;
    letter-spacing: .08em; background: var(--ink); color: var(--lane);
    padding: .2rem .5rem; white-space: nowrap;
  }
  .ann__title { font-family: var(--display); font-weight: 600; }
  .ann__excerpt { color: var(--ink-soft); min-width: 0; }
  .ann__meta {
    font-family: var(--mono); font-size: .7rem; text-transform: uppercase;
    letter-spacing: .04em; color: var(--ink-soft); margin-left: auto; white-space: nowrap;
  }
  @media (max-width: 640px) {
    .ann__excerpt { display: none; }
    .ann__meta { margin-left: 0; }
  }
</style>